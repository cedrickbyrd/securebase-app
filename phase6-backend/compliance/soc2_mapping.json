{
  "framework": "SOC2",
  "version": "2017",
  "description": "SOC 2 Trust Services Criteria mappings for AWS Config managed rules.",
  "last_updated": "2026-05-17",
  "controls": [
    {"rule_name": "cloudtrail-enabled", "config_rule": "cloudtrail-enabled", "control_id": "CC7.2", "control_name": "System Monitoring", "framework": "SOC2", "severity": "Critical", "description": "CloudTrail must be enabled to provide immutable security audit trails."},
    {"rule_name": "cloudtrail-s3-dataevents-enabled", "config_rule": "cloudtrail-s3-dataevents-enabled", "control_id": "CC7.2", "control_name": "System Monitoring", "framework": "SOC2", "severity": "High", "description": "CloudTrail S3 data events must be enabled to track object-level access activity."},
    {"rule_name": "cloudtrail-log-file-validation-enabled", "config_rule": "cloudtrail-log-file-validation-enabled", "control_id": "CC7.2", "control_name": "System Monitoring", "framework": "SOC2", "severity": "High", "description": "CloudTrail log file validation must be enabled to detect tampering."},
    {"rule_name": "guardduty-enabled-centralized", "config_rule": "guardduty-enabled-centralized", "control_id": "CC7.1", "control_name": "Anomaly Detection", "framework": "SOC2", "severity": "Critical", "description": "GuardDuty must be centralized and enabled for managed threat detection."},
    {"rule_name": "iam-password-policy", "config_rule": "iam-password-policy", "control_id": "CC6.1", "control_name": "Logical Access Controls", "framework": "SOC2", "severity": "High", "description": "IAM password policy must enforce secure password complexity and lifecycle settings."},
    {"rule_name": "iam-root-access-key-check", "config_rule": "iam-root-access-key-check", "control_id": "CC6.1", "control_name": "Logical Access Controls", "framework": "SOC2", "severity": "Critical", "description": "Root access keys must not exist to prevent unmanaged privileged credentials."},
    {"rule_name": "iam-user-mfa-enabled", "config_rule": "iam-user-mfa-enabled", "control_id": "CC6.2", "control_name": "Authentication", "framework": "SOC2", "severity": "High", "description": "MFA must be enabled for IAM users to enforce strong authentication."},
    {"rule_name": "root-account-mfa-enabled", "config_rule": "root-account-mfa-enabled", "control_id": "CC6.2", "control_name": "Authentication", "framework": "SOC2", "severity": "Critical", "description": "MFA must be enabled for the root account to protect break-glass access."},
    {"rule_name": "s3-bucket-public-read-prohibited", "config_rule": "s3-bucket-public-read-prohibited", "control_id": "CC6.6", "control_name": "Data Access Restriction", "framework": "SOC2", "severity": "Critical", "description": "S3 buckets must prohibit public read access to prevent unauthorized disclosure."},
    {"rule_name": "s3-bucket-public-write-prohibited", "config_rule": "s3-bucket-public-write-prohibited", "control_id": "CC6.6", "control_name": "Data Access Restriction", "framework": "SOC2", "severity": "Critical", "description": "S3 buckets must prohibit public write access to protect data integrity."},
    {"rule_name": "s3-bucket-ssl-requests-only", "config_rule": "s3-bucket-ssl-requests-only", "control_id": "CC6.7", "control_name": "Transmission Protection", "framework": "SOC2", "severity": "High", "description": "S3 buckets must enforce TLS-only transport for requests."},
    {"rule_name": "encrypted-volumes", "config_rule": "encrypted-volumes", "control_id": "CC6.7", "control_name": "Encryption at Rest", "framework": "SOC2", "severity": "High", "description": "EBS volumes must be encrypted to protect data at rest."},
    {"rule_name": "rds-storage-encrypted", "config_rule": "rds-storage-encrypted", "control_id": "CC6.7", "control_name": "Encryption at Rest", "framework": "SOC2", "severity": "High", "description": "RDS storage encryption is required to secure database data at rest."},
    {"rule_name": "vpc-flow-logs-enabled", "config_rule": "vpc-flow-logs-enabled", "control_id": "CC7.2", "control_name": "Network Monitoring", "framework": "SOC2", "severity": "High", "description": "VPC flow logs must be enabled for network telemetry and investigation."},
    {"rule_name": "restricted-ssh", "config_rule": "restricted-ssh", "control_id": "CC6.6", "control_name": "Network Access Restriction", "framework": "SOC2", "severity": "High", "description": "Security groups must restrict inbound SSH from untrusted sources."},
    {"rule_name": "restricted-common-ports", "config_rule": "restricted-common-ports", "control_id": "CC6.6", "control_name": "Network Access Restriction", "framework": "SOC2", "severity": "High", "description": "Common administrative ports must be restricted from broad ingress exposure."},
    {"rule_name": "access-keys-rotated", "config_rule": "access-keys-rotated", "control_id": "CC6.3", "control_name": "Credential Lifecycle", "framework": "SOC2", "severity": "High", "description": "IAM access keys must rotate every 90 days to reduce credential compromise risk."},
    {"rule_name": "secretsmanager-rotation-enabled-check", "config_rule": "secretsmanager-rotation-enabled-check", "control_id": "CC6.3", "control_name": "Credential Lifecycle", "framework": "SOC2", "severity": "High", "description": "Secrets Manager secrets must have automatic rotation enabled."},
    {"rule_name": "s3-bucket-server-side-encryption-enabled", "config_rule": "s3-bucket-server-side-encryption-enabled", "control_id": "CC6.7", "control_name": "Encryption at Rest", "framework": "SOC2", "severity": "High", "description": "S3 buckets must use server-side encryption for stored objects."},
    {"rule_name": "s3-bucket-versioning-enabled", "config_rule": "s3-bucket-versioning-enabled", "control_id": "CC8.1", "control_name": "Change Management", "framework": "SOC2", "severity": "Medium", "description": "S3 bucket versioning must be enabled to support rollback and change traceability."}
  ]
}
