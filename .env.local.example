# .env.local.example — copy to .env.local for local development
# DO NOT commit .env.local (it is gitignored)

# LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566

# LocalStack Pro token (optional — needed for AWS Config service)
# LOCALSTACK_AUTH_TOKEN=your_token_here

# Postgres (local)
RDS_HOST=localhost
RDS_PORT=5432
RDS_DATABASE=securebase
RDS_USER=securebase
RDS_PASSWORD=localdev

# Lambda env vars (for sam local invoke)
COMPLIANCE_SCORES_TABLE=securebase-compliance-scores
CONTROL_VIOLATION_TABLE=control_violation_log
MAPPINGS_BUCKET=securebase-mappings-local
LOG_LEVEL=DEBUG

# Portal (phase3a-portal)
VITE_API_BASE_URL=http://localhost:3001
VITE_USE_MOCK_API=true
VITE_ENV=development
VITE_ANALYTICS_ENABLED=false
