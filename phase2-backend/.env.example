# SecureBase Phase 2 Backend — Lambda Environment Variables
# Copy this file to .env and update with your values for local development.
# In production, these are injected as Lambda environment variables via Terraform.
# NEVER commit a .env file with real secrets to version control.

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=dev
AWS_REGION=us-east-1
LOG_LEVEL=INFO

# ===========================================
# DATABASE (Aurora Serverless v2 PostgreSQL)
# ===========================================
# RDS Proxy endpoint (preferred) or direct cluster endpoint
RDS_ENDPOINT=securebase-dev.cluster-xxxxxxxx.us-east-1.rds.amazonaws.com
RDS_PORT=5432
DB_HOST=securebase-dev.cluster-xxxxxxxx.us-east-1.rds.amazonaws.com
DB_NAME=securebase
DB_USER=securebase_admin

# AWS Secrets Manager ARN for DB credentials (used in production)
RDS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:securebase/dev/db-credentials
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:securebase/dev/db-credentials

# ===========================================
# AUTHENTICATION
# ===========================================
# JWT signing secret — must be a long random string in production
JWT_SECRET=change-me-to-a-random-256-bit-secret-in-production
TOKEN_TTL_SECS=3600
SESSION_DURATION=28800

# ===========================================
# DYNAMODB TABLES
# ===========================================
CACHE_TABLE=securebase-dev-cache
DDB_TABLE_CACHE=securebase-dev-cache
CUSTOMERS_TABLE=securebase-dev-customers
METRICS_TABLE=securebase-dev-metrics
METRICS_HISTORY_TABLE=securebase-metrics-history
EVENTS_TABLE=securebase-dev-events
RATE_LIMIT_TABLE=securebase-dev-rate-limits
AUDIT_TABLE_NAME=securebase-dev-audit
AUDIT_TRAIL_TABLE=securebase-audit-trail
COMPLIANCE_VIOLATIONS_TABLE=securebase-compliance-violations
NOTIFICATIONS_TABLE=securebase-dev-notifications
INVOICES_TABLE=securebase-dev-invoices
FORECASTS_TABLE=securebase-dev-forecasts
REPORTS_TABLE=securebase-dev-reports
SUBSCRIPTIONS_TABLE=securebase-dev-subscriptions
SUPPORT_TICKETS_TABLE=securebase-dev-support-tickets
TICKET_COMMENTS_TABLE=securebase-dev-ticket-comments
WEBHOOKS_TABLE=securebase-dev-webhooks
DELIVERIES_TABLE=securebase-dev-webhook-deliveries
SCHEDULES_TABLE=securebase-dev-schedules
DEPLOYMENTS_TABLE=securebase-dev-deployments
TEMPLATES_TABLE=securebase-dev-templates

# ===========================================
# STRIPE (REQUIRED FOR PAYMENT PROCESSING)
# ===========================================
# Use sk_test_... key for dev/staging; sk_live_... for production
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
STRIPE_PRICE_STANDARD=price_standard_id
STRIPE_PRICE_HEALTHCARE=price_healthcare_id
STRIPE_PRICE_FINTECH=price_fintech_id
STRIPE_PRICE_GOVERNMENT=price_government_id
STRIPE_PILOT_COUPON=PILOT50

# ===========================================
# AWS SES (EMAIL)
# ===========================================
SES_FROM_EMAIL=noreply@securebase.tximhotep.com
SES_SENDER_EMAIL=noreply@securebase.tximhotep.com

# ===========================================
# AWS SNS (NOTIFICATIONS)
# ===========================================
ONBOARDING_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:securebase-dev-onboarding
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:securebase-dev-notifications
SNS_TOPIC=arn:aws:sns:us-east-1:123456789012:securebase-dev-notifications
SECURITY_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:securebase-dev-security

# ===========================================
# LAMBDA ORCHESTRATION
# ===========================================
ONBOARDING_FUNCTION_NAME=securebase-dev-trigger-onboarding

# ===========================================
# S3 BUCKETS
# ===========================================
AUDIT_LOG_BUCKET=securebase-dev-audit-logs

# ===========================================
# KMS ENCRYPTION
# ===========================================
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-kms-key-id

# ===========================================
# API / PORTAL CONFIGURATION
# ===========================================
ALLOWED_ORIGIN=https://securebase.tximhotep.com
PORTAL_URL=https://securebase.tximhotep.com
CALLBACK_BASE_URL=https://api.securebase.tximhotep.com

# ===========================================
# RATE LIMITING / PAGINATION
# ===========================================
CACHE_TTL_SECONDS=3600
MAX_PAGE_SIZE=100
MAX_RETRIES=3
WEBHOOK_TIMEOUT=30
WEBHOOK_SECRET_KEY=change-me-to-a-random-secret

# ===========================================
# DEMO ENVIRONMENT ONLY
# ===========================================
DEMO_EMAIL=demo@securebase.tximhotep.com
DEMO_PASSWORD=change-me-demo-password
