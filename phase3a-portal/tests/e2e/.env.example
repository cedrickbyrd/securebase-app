# SecureBase Playwright E2E — environment variables
# Copy this file to .env.local and fill in values for local runs.
# In CI, these are injected as GitHub Actions secrets.
# Never commit .env.local — it is in .gitignore.

# Portal base URL
PORTAL_URL=https://portal.securebase.tximhotep.com

# API base URL (direct Lambda — bypasses Netlify proxy)
API_URL=https://9xyetu7zq3.execute-api.us-east-1.amazonaws.com/prod

# ── Tenant credentials (Standard tier) ───────────────────────────────────
# Maps to GitHub secret: PLAYWRIGHT_TEST_EMAIL / PLAYWRIGHT_TEST_PASSWORD
# Mailbox: e2e@securebase.tximhotep.com (sub-address routing)
TEST_EMAIL=e2e+tenantA@securebase.tximhotep.com
TEST_PASSWORD=your_local_tenant_password_here

# ── Admin credentials ─────────────────────────────────────────────────────
# Maps to GitHub secret: PLAYWRIGHT_ADMIN_EMAIL / PLAYWRIGHT_ADMIN_PASSWORD
# Mailbox: e2e@securebase.tximhotep.com (sub-address routing)
TEST_ADMIN_EMAIL=e2e+admin@securebase.tximhotep.com
TEST_ADMIN_PASSWORD=your_local_admin_password_here

# ── Tenant B (cross-tenant isolation tests) ───────────────────────────────
# Maps to GitHub secret: PLAYWRIGHT_TENANT_B_EMAIL / PLAYWRIGHT_TENANT_B_PASSWORD
TEST_TENANT_B_EMAIL=e2e+tenantB@securebase.tximhotep.com
TEST_TENANT_B_PASSWORD=your_local_tenantB_password_here

# ── Notes ─────────────────────────────────────────────────────────────────
# The backend, database unique constraints, and auth provider must treat the
# full string including +suffix as the unique identifier. Do NOT collapse
# e2e+admin and e2e+tenantA into the same user profile.
#
# Tests that require credentials use test.skip() when passwords are absent
# so local runs without secrets don't fail the suite.
#
# Never use real customer emails or production user credentials in this file.
