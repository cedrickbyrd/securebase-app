# SecureBase Marketing Site Environment Variables
# Copy this file to .env.local and update with your values
# NEVER commit .env.local to version control

# ===========================================
# API CONFIGURATION (REQUIRED)
# ===========================================
# Lambda backend API base URL (used for /signup and other server-side calls)
VITE_API_BASE_URL=https://api.securebase.tximhotep.com
# Alias used by some older components; keep in sync with VITE_API_BASE_URL
VITE_API_URL=https://api.securebase.tximhotep.com

# ===========================================
# ENVIRONMENT
# ===========================================
VITE_ENV=development

# ===========================================
# STRIPE CONFIGURATION (REQUIRED FOR SIGNUP)
# ===========================================
# Use test key (pk_test_...) for development/staging
# Use live key (pk_live_...) for production
VITE_STRIPE_PILOT_PRICE_ID=price_YOUR_PILOT_PRICE_ID_HERE

# ===========================================
# SUPABASE CONFIGURATION (LEGACY — see PR #508)
# ===========================================
# These are no longer used by the marketing site signup flow.
# The /signup route calls the Lambda backend directly via VITE_API_BASE_URL.
# Kept here for reference; safe to leave empty.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ===========================================
# ANALYTICS (OPTIONAL)
# ===========================================
# Google Analytics 4 Measurement ID
# HIPAA requirement: must use anonymize_ip=true (see src/utils/analytics.ts)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# FEATURE FLAGS (OPTIONAL)
# ===========================================
# Set to 'true' to enable demo/preview mode (bypasses live API calls)
VITE_DEMO_MODE=false

# Maximum pilot program spots available
VITE_PILOT_MAX_SPOTS=50
